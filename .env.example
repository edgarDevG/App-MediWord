# ════════════════════════════════════════════════════════════
# MediWord HSM v2 — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el .env con credenciales reales.
# ════════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ─────────────────────────────────
# Contraseña del superusuario de PostgreSQL
POSTGRES_PASSWORD=Ed1001978273

# Nombre de la base de datos (default: MEDW)
POSTGRES_DB=MEDW

# Usuario de PostgreSQL (default: postgres)
POSTGRES_USER=postgres

# ── Puertos de los servicios ─────────────────────────────────
# Puerto expuesto en el host para el frontend (default: 80)
FRONTEND_PORT=80

# Puerto expuesto en el host para el backend API (default: 8001)
# Solo necesario si accedes al backend directamente (sin nginx proxy)
BACKEND_PORT=8001

# ── Desarrollo local (sin Docker) ───────────────────────────
# URL del backend para el frontend en desarrollo local (Vite dev server)
# En Docker, el nginx proxy maneja esto automáticamente con ruta relativa /api/v1
# VITE_API_URL=http://localhost:8001/api/v1
